meta {
  name: 9. Trigger - Transaction Aggregation
  type: http
  seq: 9
}

post {
  url: {{scheduler_url}}/api/dashboard/trigger/t
  body: none
  auth: bearer
}

headers {
  Authorization: Bearer {{access_token}}
  Business-Segment: KEY
}

vars:pre-request {
  scheduler_url: http://localhost:8080/mission-happinessApi/app/scheduler
  access_token: eyJhbGciOiJIUzM4NCJ9..aW6e-02pRHEhBx9zs9QrkvNRHQUM5-fkzfjJqTm2Nzw2qBaQ484H9cqSDzpCEZSn
}

settings {
  encodeUrl: false
  timeout: 300000
}

docs {
  Manually triggers the transaction aggregation job.
  Aggregates UTCL_TRANSACTIONS into UTCL_MONTHLY_AGGREGATE.
  Required before running the Trade Cement Pipeline (Stage 0 gate checks this).
  
  Response: { status: "SUCCESS", job: "transaction-aggregation", durationMs: ... }
}
