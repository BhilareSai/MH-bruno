meta {
  name: 1. Validate Link - Trade
  type: http
  seq: 1
}

post {
  url: {{base_url}}/admin/api/v1/feedback/trade/validate-link
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "9WKG9rkeQX2xoH3dOy__I5uipWYe9T-6RPcDEDDYgLlJ6tuZRoee7ul7BowwHRsiEoc3OaERzR42Cs1V"
  }
}

settings {
  encodeUrl: false
  timeout: 0
}

docs {
  Page-load pre-check for the TRADE feedback form.
  Frontend calls this with the encrypted token from the feedback link URL.

  The token decrypts to: segment | customerCode | surveyId | channel | roleCode
  For TRADE: roleCode is always empty.

  TOKEN GENERATION:
    Secret used: MH-Feedback-Dev-2026
    Decrypts to: TRADE|410104K002|SURVEY-2026-0001|SMS|
    Customer:    410104K002 (K SQUARE GRANITE PRIVATE LIMITED)

  ⚠️  Run mh-admin-service with: FEEDBACK_LINK_SECRET=MH-Feedback-Dev-2026
      To regenerate tokens: node supporting-files/generate-test-tokens/generate-test-tokens.js "MH-Feedback-Dev-2026"

  Outcomes:
    200 → { customerName, businessSegment:"TRADE", blankLink:false }
          TRADE still requires the mobile step — feedbackToken is NOT returned here.
    404 CUSTOMER_NOT_FOUND          → invalid customerCode in token
    409 FEEDBACK_ALREADY_SUBMITTED  → both feedback + callback submitted this month
    400 validation error            → token blank
}
