meta {
  name: 2d. Validate Link - Key (SITE_QUALITY_MANAGER)
  type: http
  seq: 6
}

post {
  url: {{base_url}}/admin/api/v1/feedback/key/validate-link
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "xWHreJTf0kRjHyoppYL4KDYM4bWNXhPBXFTc59hLCH3FRsV2VE-V8pChyFoUD099Ji8iA5ilGXwJlkCDECBx"
  }
}

script:post-response {
  var json = res.getBody();
  if (json.data && json.data.feedbackToken) {
    bru.setVar('feedback_token', json.data.feedbackToken);
    console.log('feedback_token saved:', json.data.feedbackToken);
  }
}

settings {
  encodeUrl: false
  timeout: 0
}

