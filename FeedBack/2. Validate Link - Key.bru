meta {
  name: 2. Validate Link - Key (PROJECT_MANAGER)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/admin/api/v1/feedback/key/validate-link
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "cnayN8hbcm366WsrgAqJzpn38f1DodBSJMKBQxyIDfq-bCpAhuSUMARmNwRBUdJ_D2GwEHSHbeTsDK200WqhQPM"
  }
}

script:post-response {
  var json = res.getBody();
  if (json.data && json.data.touchpointId) {
    bru.setVar('touchpoint_id', json.data.touchpointId);
    console.log('touchpoint_id saved:', json.data.touchpointId);
  }
  if (json.data && json.data.touchpointRole) {
    bru.setVar('touchpoint_role', json.data.touchpointRole);
    console.log('touchpointRole:', json.data.touchpointRole);
  }
  if (json.data && json.data.surveyId) {
    bru.setVar('survey_id', json.data.surveyId);
  }
}

settings {
  encodeUrl: false
  timeout: 0
}

docs {
  Page-load pre-check for the KEY feedback form (PROJECT_MANAGER role).
  No mobile step — feedbackToken is returned directly in the response.
  
  TOKEN GENERATION:
    Secret used  : MH-Feedback-Dev-2026
    Decrypts to  : KEY|610101A132|SURVEY-2026-0001|Email|R04
    CustomerCode : 610101A132
    Role code    : R04 → PROJECT_MANAGER
  
  ⚠️  Run mh-admin-service with: FEEDBACK_LINK_SECRET=MH-Feedback-Dev-2026
      To regenerate tokens: node supporting-files/generate-test-tokens/generate-test-tokens.js "MH-Feedback-Dev-2026"
  
  Outcomes:
    200 → {
            customerName, siteId, siteName, groupId, groupName, lob, mappingLevel,
            touchpointRole: "PROJECT_MANAGER",
            feedbackToken: "<JWT to submit with>",
            businessSegment: "KEY"
          }
    404 CUSTOMER_NOT_FOUND  → touchpoint not found for (customerCode, role, KEY)
    409 FEEDBACK_ALREADY_SUBMITTED
    400 validation error
}
