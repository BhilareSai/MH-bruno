meta {
  name: 3. Validate Link - NonTrade (PROJECT_MANAGER)
  type: http
  seq: 3
}

post {
  url: {{base_url}}/admin/api/v1/feedback/non-trade/validate-link
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "jjhvq8AquWRBW-8W8S8WgiFGoroUCV3_YHNejG_IdNDvlV-y8En2mwuxupZZoTZu1Ipodfgqaaj6egK4rDF5ba0"
  }
}

script:post-response {
  var json = res.getBody();
  if (json.data && json.data.feedbackToken) {
    bru.setVar('feedback_token', json.data.feedbackToken);
    console.log('feedback_token saved:', json.data.feedbackToken);
  }
  if (json.data && json.data.touchpointRole) {
    bru.setVar('touchpoint_role', json.data.touchpointRole);
    console.log('touchpointRole:', json.data.touchpointRole);
  }
}

settings {
  encodeUrl: false
  timeout: 0
}

docs {
  Page-load pre-check for the NON_TRADE feedback form (PROJECT_MANAGER role).
  No mobile step — feedbackToken is returned directly in the response.

  TOKEN GENERATION:
    Secret used  : MH-Feedback-Dev-2026
    Decrypts to  : NONTRADE|630102B069|SURVEY-2026-0001|Email|R04
    CustomerCode : 630102B069 (placeholder — add a real NONTRADE customer code)
    Role code    : R04 → PROJECT_MANAGER

  ⚠️  Run mh-admin-service with: FEEDBACK_LINK_SECRET=MH-Feedback-Dev-2026
      To regenerate tokens: node supporting-files/generate-test-tokens/generate-test-tokens.js "MH-Feedback-Dev-2026"
      Update TEST_CASES in the script with a real NONTRADE customerCode once data is loaded.

  Outcomes:
    200 → {
            customerName, siteId, siteName, groupId, groupName, lob, mappingLevel,
            touchpointRole: "PROJECT_MANAGER",
            feedbackToken: "<JWT>",
            businessSegment: "NONTRADE"
          }
    404 CUSTOMER_NOT_FOUND  → NONTRADE touchpoint not found
    409 FEEDBACK_ALREADY_SUBMITTED
}
