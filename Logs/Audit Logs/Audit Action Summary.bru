meta {
  name: Audit Action Summary
  type: http
  seq: 4
}

get {
  url: {{base_url}}/data/api/v1/data/audit/logs/action-summary?auditLogId=1
  body: none
  auth: inherit
}

params:query {
  auditLogId: 1
}

headers {
