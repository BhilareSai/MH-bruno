meta {
  name: Audit Filter Options
  type: http
  seq: 3
}

get {
  url: {{base_url}}/data/api/v1/data/audit/filter-options?field=module&page=1&size=5
  body: none
  auth: inherit
}

params:query {
  field: module
  page: 1
  size: 5
  ~search: HUD
}

headers {
  Authorization: Bearer {{access_token}}
  Business-Segment: TRADE
}

settings {
  encodeUrl: true
}

docs {
  Distinct values for audit dropdowns.
  Supported fields: module, actionPerformed, status.
  size: max 20.
}
