meta {
  name: Notification Log Detail
  type: http
  seq: 5
}

get {
  url: {{base_url}}/app/data/api/v1/data/notification-logs/1
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
  Business-Segment: TRADE
}

settings {
  encodeUrl: true
}

docs {
  Returns full log entry including rendered content/message and variables.
  EMAIL: rendered HTML content.
  SMS/WhatsApp: rendered message with template variables.
}
