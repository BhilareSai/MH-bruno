meta {
  name: Update user againts Depos
  type: http
  seq: 12
}

put {
  url: {{base_url}}/ops/api/v1/lx/drivers/far-mapping/reassign-user
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Business-Segment: Trade
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "driverId": 123,
    "depotCodes": [
      "DEP001",
      "DEP002"
    ],
    "newUserId": "EMP456"
  }
}

settings {
  encodeUrl: false
  timeout: 0
}
