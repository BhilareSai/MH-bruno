meta {
  name: 6. Reset Password
  type: http
  seq: 6
}

post {
  url: {{base_url}}/admin/api/v1/auth/reset-password
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{temp_token}}
}

body:json {
  {
    "password": "NewPass@1234",
    "confirmPassword": "NewPass@1234"
  }
}

settings {
  encodeUrl: true
}

docs {
  Reset password. Requires temp_token from Verify OTP (FORGOT_PASSWORD purpose).
}
