meta {
  name: 5. Delete Preset Q&A
  type: http
  seq: 6
}

delete {
  url: {{base_url}}/admin/api/v1/preset-qa?entityId={{preset_qa_id}}
  body: none
  auth: inherit
}

params:query {
  entityId: {{preset_qa_id}}
}

headers {
  Authorization: Bearer {{access_token}}
  Business-Segment: Trade
}

settings {
  encodeUrl: true
}

docs {
  Soft-deletes a Preset Q&A (sets status to INACTIVE). Segment ownership is validated.
}
