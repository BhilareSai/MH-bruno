meta {
  name: 10. Get Monthly Schedule
  type: http
  seq: 5
}

get {
  url: {{base_url}}/ops/api/v1/huddles/schedule?month=3&year=2026
  body: none
  auth: inherit
}

params:query {
  month: 3
  year: 2026
}

headers {
  Authorization: Bearer {{access_token}}
}

settings {
  encodeUrl: true
}

docs {
  Fetches all scheduled huddles for a given month/year (calendar view).

  **Response:** `ApiResponse<List<HuddleScheduleResponseDTO>>`.
}
