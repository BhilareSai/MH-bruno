meta {
  name: 7. Get Huddle Details
  type: http
  seq: 2
}

get {
  url: {{base_url}}/ops/api/v1/huddles/{{huddleId}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
}

settings {
  encodeUrl: true
}

docs {
  Fetches complete details of a huddle including regions, meeting info, and action items.

  Action items are now fetched directly from `MH_ACTION_ITEM` (no bridge table).

  **Response:** `ApiResponse<HuddleDetailsResponseDTO>`.
}
