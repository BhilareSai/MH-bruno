meta {
  name: API #6 - Update Driver Status
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/api/v1/lx/drivers/{{driverId}}/status?status=INACTIVE
  body: none
  auth: inherit
}

params:query {
  status: INACTIVE
}

headers {
  Content-Type: application/json
  Business-Segment: Trade
  Authorization: Bearer {{access_token}}
}

settings {
  encodeUrl: true
}
