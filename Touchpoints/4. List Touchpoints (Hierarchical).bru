meta {
  name: 4. List Touchpoints (Hierarchical)
  type: http
  seq: 4
}

get {
  url: http://localhost:8080/ops/api/v1/touchpoints?page=1&pageSize=5&search=AFCon
  body: none
  auth: inherit
}

params:query {
  page: 1
  pageSize: 5
  search: AFCon
  ~surveyEligible: true
}

headers {
  Content-Type: application/json
  Business-Segment: TRADE
  Authorization: Bearer {{access_token}}
}

vars:pre-request {
  baseUrl: http://localhost:8080
}

settings {
  encodeUrl: true
  timeout: 0
}
