meta {
  name: Get User by Email
  type: http
  seq: 3
}

get {
  url: {{base_url}}/admin/api/v1/admin/users/by-email?email=user@example.com&mode=existing
  body: none
  auth: inherit
}

params:query {
  email: user@example.com
  mode: existing
}

headers {
  Authorization: Bearer {{access_token}}
}

settings {
  encodeUrl: true
}

docs {
  Lookup user by email.
  mode=existing (default): searches MH_USERS only.
  mode=new: verifies user is NOT in MH_USERS, then fetches from UTCL_USER.
}
