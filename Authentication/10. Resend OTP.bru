meta {
  name: 10. Resend OTP
  type: http
  seq: 10
}

post {
  url: {{base_url}}/admin/api/v1/auth/resend-otp
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "user@example.com",
    "purpose": "FIRST_TIME_LOGIN"
  }
}

settings {
  encodeUrl: true
}

docs {
  Resend OTP. Purpose: FIRST_TIME_LOGIN or FORGOT_PASSWORD.
}
