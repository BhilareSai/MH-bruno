meta {
  name: 5. Forgot Password
  type: http
  seq: 5
}

post {
  url: {{base_url}}/admin/api/v1/auth/forgot-password
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "user@example.com"
  }
}

settings {
  encodeUrl: true
}

docs {
  Send OTP for password reset. Follow with Verify OTP (FORGOT_PASSWORD) then Reset Password.
}
