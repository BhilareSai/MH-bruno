meta {
  name: List Temp Users
  type: http
  seq: 1
}

get {
  url: {{base_url}}/admin/api/v1/admin/temp-users?page=0&size=20
  body: none
  auth: inherit
}

params:query {
  page: 0
  size: 20
  ~search: 
  ~businessSegment: TRADE
  ~departmentName: 
  ~roleName: 
  ~zoneName: 
  ~regionName: 
  ~depotName: 
}

headers {
  Authorization: Bearer {{access_token}}
}

settings {
  encodeUrl: true
}

docs {
  Get paginated list of temp users. Enable query params as needed to filter.
}
